# ================================================================
# Kissan AI Advisor — Backend Configuration
# ================================================================
# Step 1: Copy this file → .env
#   Windows CMD:  copy .env.example .env
#   Windows PS:   Copy-Item .env.example .env
#   Linux/Mac:    cp .env.example .env
#
# Step 2: Get a FREE Groq API key:
#   → Go to https://console.groq.com
#   → Sign up (free, no credit card needed)
#   → Create API Key → copy it below
#   → Free tier: 6000 tokens/minute, 500,000 tokens/day
# ================================================================

# ---- REQUIRED: Your Groq API key (free at console.groq.com) ----
GROQ_API_KEY=gsk_your_groq_api_key_here

# ---- Server ----
HOST=0.0.0.0
PORT=8000

# ---- CORS: Frontend URLs allowed to call this backend ----
# In production, replace with your actual Vercel URL
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ---- LLM Settings ----
# Model: llama-3.1-8b-instant = fastest on Groq free tier
GROQ_MODEL=llama-3.1-8b-instant
MAX_TOKENS=600

# ---- RAG Settings ----
TOP_K=3
